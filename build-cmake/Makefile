	$(MAKE) $(MAKESILENT) -f CMakeFiles/bhrt_core.dir/build.make CMakeFiles/bhrt_core.dir/triangulation.cpp.s
.PHONY : triangulation.cpp.s

ts_color.o: ts_color.cpp.o
.PHONY : ts_color.o

# target to build an object file
ts_color.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/bhrt_core.dir/build.make CMakeFiles/bhrt_core.dir/ts_color.cpp.o
.PHONY : ts_color.cpp.o

ts_color.i: ts_color.cpp.i
.PHONY : ts_color.i

# target to preprocess a source file
ts_color.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/bhrt_core.dir/build.make CMakeFiles/bhrt_core.dir/ts_color.cpp.i
.PHONY : ts_color.cpp.i

ts_color.s: ts_color.cpp.s
.PHONY : ts_color.s

# target to generate assembly for a file
ts_color.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/bhrt_core.dir/build.make CMakeFiles/bhrt_core.dir/ts_color.cpp.s
.PHONY : ts_color.cpp.s

